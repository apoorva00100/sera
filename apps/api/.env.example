GROQ_API_KEY=

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# Optional — fill in to enable social login. Server runs email/password-only until set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Production only — leave unset for local dev, defaults are used instead.
# PORT=                        # injected automatically by most hosts (e.g. Railway)
# WEB_ORIGIN=                  # deployed web app URL, e.g. https://app.yourdomain.com
# DB_PATH=                     # path to the SQLite file on a persistent volume, e.g. /data/ape.db
